# Copy this file to .env and fill in the values.
#
#   PowerShell:  Copy-Item .env.example .env
#
# Required for the LLM calls (planner / research / writer / editor agents).
OPENAI_API_KEY=

# Required for the Tavily web-search tool used by the research agent.
TAVILY_API_KEY=

# Optional. Only set this if you were given a custom Tavily base URL
# (e.g. a DeepLearning.AI proxy). Leave empty to use the default Tavily API.
DLAI_TAVILY_BASE_URL=

# Optional. Defaults to a local SQLite file (sqlite:///./tasks.db) when unset,
# so you do NOT need a Postgres server to run locally.
# Example Postgres: postgresql://user:password@localhost:5432/agents
DATABASE_URL=

# Optional model overrides (defaults shown). Faster planner/editor lower latency+cost.
# PLANNER_MODEL=openai:gpt-4.1-mini
# RESEARCH_MODEL=openai:gpt-4.1-mini
# WRITER_MODEL=openai:gpt-4.1-mini
# EDITOR_MODEL=openai:gpt-4.1-nano

# Set EVAL_ENABLED=0 to skip the LLM-as-judge evaluation after each run.
# EVAL_ENABLED=1
